{
  "name": "silent-cart",
  "version": "0.1.0",
  "private": true,
  "description": "SilentCart is a self-hosted, Monero-only Telegram digital fulfillment bot.",
  "author": "Krypera",
  "type": "module",
  "engines": {
    "node": ">=20.11.0"
  },
  "scripts": {
    "start": "tsx src/index.ts",
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "ci": "npm run build && npm test && npm run test:postgres",
    "test": "vitest run",
    "test:postgres": "vitest run tests/integration/postgresSmoke.test.ts",
    "test:watch": "vitest",
    "migrate:up": "tsx src/db/migrator.ts",
    "migrate:create": "tsx src/db/createMigration.ts",
    "ops:reencrypt": "tsx src/ops/reencryptPayloads.ts",
    "ops:doctor": "tsx src/ops/doctor.ts",
    "ops:generate-key": "tsx src/ops/generateEncryptionKey.ts",
    "ops:seed-demo": "tsx src/ops/seedDemo.ts"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "pg": "^8.12.0",
    "qrcode": "^1.5.4",
    "telegraf": "^4.16.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "@types/pg": "^8.11.11",
    "@types/qrcode": "^1.5.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
