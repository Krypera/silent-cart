NODE_ENV=development
BOT_TOKEN=replace-me
DATABASE_URL=postgres://silentcart:silentcart@postgres:5432/silentcart
ADMIN_TELEGRAM_USER_IDS=123456789
FULFILLMENT_ENCRYPTION_KEY=replace-with-64-char-hex
RETENTION_DAYS=30
QUOTE_LIFETIME_MINUTES=30
USD_REFERENCE_ENABLED=true
XMR_ACCOUNT_INDEX=0
XMR_WALLET_RPC_URL=http://host.docker.internal:18083/json_rpc
XMR_WALLET_RPC_USERNAME=
XMR_WALLET_RPC_PASSWORD=
MONEROD_RPC_URL=http://host.docker.internal:18081/get_info
MONEROD_RPC_USERNAME=
MONEROD_RPC_PASSWORD=
COINGECKO_API_BASE_URL=https://api.coingecko.com/api/v3
PAYMENT_SCAN_INTERVAL_MS=15000
ORDER_EXPIRY_INTERVAL_MS=30000
RETENTION_PURGE_INTERVAL_MS=3600000
FULFILLMENT_RETRY_INTERVAL_MS=60000
EXPIRED_LICENSE_RESERVATION_RELEASE_MINUTES=1440
WALLET_SCAN_BATCH_SIZE=250
WALLET_HEALTH_CHECK_INTERVAL_MS=60000
WALLET_STALE_SCAN_ALERT_MS=180000
TELEGRAM_RETRY_ATTEMPTS=4
TELEGRAM_RETRY_BASE_DELAY_MS=1000
TELEGRAM_RETRY_MAX_DELAY_MS=10000
OPERATOR_ALERT_COOLDOWN_MS=900000
